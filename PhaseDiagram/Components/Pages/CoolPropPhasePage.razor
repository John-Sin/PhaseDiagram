@page "/coolprop-phase"
@page "/"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using PhaseDiagram.Services.Thermo
@inject CoolPropPhaseEnvelopeService EnvelopeService

<PageTitle>CoolProp Phase Envelope</PageTitle>

<div class="container-fluid py-3">
    <div class="row">
        <div class="col-12">
            <h2>CoolProp Phase Envelope Calculator</h2>
            <p class="text-muted mb-2">
                Professional phase envelope with liquid dropout lines using Peng-Robinson or SRK equation of state
            </p>
        </div>
    </div>

    <div class="row mt-2 align-items-start">

        <!-- ── Left Panel ─────────────────────────────────────────────────── -->
        <div class="col-auto" style="width:240px;">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white py-2">
                    <h6 class="mb-0"><i class="bi bi-sliders"></i> Configuration</h6>
                </div>
                <div class="card-body px-2 py-2" style="overflow-x:hidden;">

                    <div class="mb-2">
                        <label class="form-label fw-bold mb-1" style="font-size:0.8rem;">Equation of State</label>
                        <div class="btn-group w-100" role="group">
                            <input type="radio" class="btn-check" id="backend-pr" name="backend"
                                   checked='@(selectedBackend == BackendPR)'
                                   @onchange="@(() => selectedBackend = BackendPR)" />
                            <label class="btn btn-outline-primary btn-sm" for="backend-pr">Peng-Robinson</label>
                            <input type="radio" class="btn-check" id="backend-srk" name="backend"
                                   checked='@(selectedBackend == BackendSRK)'
                                   @onchange="@(() => selectedBackend = BackendSRK)" />
                            <label class="btn btn-outline-primary btn-sm" for="backend-srk">SRK</label>
                        </div>
                    </div>

                    <div class="mb-2">
                        <div class="d-flex align-items-center gap-2 mb-1">
                            <label class="form-label fw-bold mb-0" style="font-size:0.8rem;">Liquid Dropout (%)</label>
                            <div class="form-check form-switch mb-0">
                                <input class="form-check-input" type="checkbox" id="enable-dropout"
                                       @bind="showLiquidLines" @bind:after="OnDisplayToggleChanged" />
                                <label class="form-check-label small text-muted" for="enable-dropout">
                                    @(showLiquidLines ? "On" : "Off")
                                </label>
                            </div>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="d1" @bind="showDropout1" />
                            <label class="form-check-label" for="d1">1% Liquid</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="d3" @bind="showDropout3" />
                            <label class="form-check-label" for="d3">3% Liquid</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="d5" @bind="showDropout5" />
                            <label class="form-check-label" for="d5">5% Liquid</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="d10" @bind="showDropout10" />
                            <label class="form-check-label" for="d10">10% Liquid</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="d15" @bind="showDropout15" />
                            <label class="form-check-label" for="d15">15% Liquid</label>
                        </div>
                    </div>

                    <div class="mb-2">
                        <label class="form-label fw-bold mb-1" style="font-size:0.8rem;">Fluid Composition</label>
                        <div class="btn-group w-100 mb-1" role="group">
                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="LoadGasCondensate">Gas</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="LoadDryGas">Dry</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="LoadBlackOil">Oil</button>
                        </div>
                        <div style="max-height:280px; overflow-y:auto; overflow-x:hidden;">
                            @foreach (var comp in composition.ToList())
                            {
                                <div class="row g-1 mb-1 align-items-center flex-nowrap">
                                    <div class="col-4"><small class="fw-bold">@comp.Key</small></div>
                                    <div class="col-6">
                                        <input type="number" class="form-control form-control-sm"
                                               value="@comp.Value"
                                               @oninput="@(e => UpdateComposition(comp.Key, e.Value?.ToString()))"
                                               step="0.001" min="0" max="1" />
                                    </div>
                                    <div class="col-2">
                                        <button type="button" class="btn btn-sm btn-outline-danger p-0"
                                                style="width:22px;height:22px;line-height:1;"
                                                @onclick="@(() => RemoveComponent(comp.Key))">
                                            <i class="bi bi-x"></i>
                                        </button>
                                    </div>
                                </div>
                            }
                        </div>
                        <div class="mt-1">
                            <small class="text-muted">
                                Total: <strong>@composition.Values.Sum().ToString("F4")</strong>
                                @if (Math.Abs(composition.Values.Sum() - 1.0) > 0.01)
                                {
                                    <span class="text-warning"> ⚠ Should be 1.0</span>
                                }
                            </small>
                        </div>
                        <button type="button" class="btn btn-sm btn-outline-primary w-100 mt-1"
                                @onclick="ShowAddComponentModal">
                            <i class="bi bi-plus-circle"></i> Add Component
                        </button>
                    </div>

                    <button type="button" class="btn btn-primary w-100"
                            @onclick="GenerateEnvelope" disabled="@isCalculating">
                        @if (isCalculating)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                            <span>Calculating...</span>
                        }
                        else
                        {
                            <i class="bi bi-graph-up"></i>
                            <span> Generate</span>
                        }
                    </button>

                </div>
            </div>

            @if (envelopeResult != null)
            {
                <div class="card shadow-sm mt-2">
                    <div class="card-header bg-success text-white py-1">
                        <h6 class="mb-0" style="font-size:0.85rem;">Results</h6>
                    </div>
                    <div class="card-body p-2">
                        <table class="table table-sm mb-0" style="font-size:0.8rem;">
                            <tbody>
                                <tr><td><strong>Backend:</strong></td><td>@envelopeResult.Backend</td></tr>
                                <tr>
                                    <td><strong>Fluid Type:</strong></td>
                                    <td>
                                        <span class="badge @GetFluidBadgeClass(envelopeResult.FluidType)">
                                            @CoolPropPhaseEnvelopeService.GetFluidLabel(envelopeResult.FluidType)
                                        </span>
                                    </td>
                                </tr>
                                <tr><td><strong>Bubble Pts:</strong></td><td>@envelopeResult.Bubble.Length</td></tr>
                                <tr><td><strong>Dew Pts:</strong></td><td>@envelopeResult.Dew.Length</td></tr>
                                @if (envelopeResult.Critical.HasValue)
                                {
                                    <tr><td><strong>Crit T:</strong></td><td>@envelopeResult.Critical.Value.Tcrit_F.ToString("F1") °F</td></tr>
                                    <tr><td><strong>Crit P:</strong></td><td>@envelopeResult.Critical.Value.Pcrit_psia.ToString("F0") psia</td></tr>
                                }
                                <tr><td><strong>Dropout:</strong></td><td>@envelopeResult.LiquidLines.Count lines computed</td></tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </div>
        <!-- /Left Panel -->
        <!-- ── Right Panel ────────────────────────────────────────────────── -->
        <div class="col-auto">
            <div class="card shadow-sm">
                <div class="card-header bg-secondary text-white py-2 d-flex justify-content-between align-items-center">
                    <h6 class="mb-0"><i class="bi bi-graph-up-arrow"></i> Phase Envelope Diagram</h6>
                    @if (envelopeResult != null)
                    {
                        <div class="d-flex gap-3" style="font-size:0.8rem;">
                            <div class="form-check form-check-inline mb-0">
                                <input class="form-check-input" type="checkbox" id="toggle-liq"
                                       checked="@showLiquidLines"
                                       @onchange="OnLiquidToggleHeaderChanged"
                                       style="width:14px;height:14px;" />
                                <label class="form-check-label text-white" for="toggle-liq"
                                       style="font-size:0.8rem;">Liquid Dropout</label>
                            </div>
                            <div class="form-check form-check-inline mb-0">
                                <input class="form-check-input" type="checkbox" id="toggle-retro"
                                       checked="@showRetrogradeShading"
                                       @onchange="OnRetrogradeToggleHeaderChanged"
                                       style="width:14px;height:14px;" />
                                <label class="form-check-label text-white" for="toggle-retro"
                                       style="font-size:0.8rem;">Retrograde</label>
                            </div>
                            <div class="form-check form-check-inline mb-0">
                                <input class="form-check-input" type="checkbox" id="toggle-theme"
                                       checked="@useDarkMode"
                                       @onchange="OnThemeToggleChanged"
                                       style="width:14px;height:14px;" />
                                <label class="form-check-label text-white" for="toggle-theme"
                                       style="font-size:0.8rem;">
                                    <i class="bi @(useDarkMode ? "bi-moon-fill" : "bi-sun-fill")"></i> @(useDarkMode ? "Dark" : "Light")
                                </label>
                            </div>
                        </div>
                    }
                </div>
                <div class="card-body p-2" style="position:relative;">

                    <PhaseEnvelopePlot @ref="_plotComponent"
                                       EnvelopeData="envelopeResult"
                                       ShowLiquidLines="@showLiquidLines"
                                       ShowRetrogradeShading="@showRetrogradeShading"
                                       DarkMode="@useDarkMode"
                                       PlotWidth="1125"
                                       PlotHeight="620" />

                    @if (isCalculating)
                    {
                        <div style="position:absolute;inset:0;display:flex;align-items:center;
                                                                        justify-content:center;background:rgba(255,255,255,0.85);z-index:10;">
                            <div class="text-center">
                                <div class="spinner-border text-primary"
                                     style="width:3rem;height:3rem;" role="status"></div>
                                <p class="mt-3 text-muted">Generating phase envelope...</p>
                            </div>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div style="position:absolute;inset:0;display:flex;align-items:center;
                                                                        justify-content:center;background:rgba(255,255,255,0.95);z-index:10;">
                            <div class="alert alert-danger m-3">
                                <h6>Error</h6>
                                <p class="mb-0">@errorMessage</p>
                            </div>
                        </div>
                    }

                    @if (envelopeResult == null && !isCalculating && string.IsNullOrEmpty(errorMessage))
                    {
                        <div style="position:absolute;inset:0;display:flex;align-items:center;
                                                                        justify-content:center;background:rgba(255,255,255,0.95);z-index:10;"
                             class="text-muted">
                            <div class="text-center">
                                <i class="bi bi-graph-up" style="font-size:4rem;opacity:0.3;"></i>
                                <p class="mt-3">Configure parameters and click "Generate"</p>
                            </div>
                        </div>
                    }

                </div>
            </div>
        </div>
        <!-- /Right Panel -->

    </div>
</div>

@if (showAddComponent)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Add Component</h5>
                    <button type="button" class="btn-close"
                            @onclick="@(() => showAddComponent = false)"></button>
                </div>
                <div class="modal-body">
                    <label class="form-label">Select Component</label>
                    <select class="form-select" @bind="selectedNewComponent">
                        <option value="">-- Select --</option>
                        @foreach (var comp in availableComponents)
                        {
                            if (!composition.ContainsKey(comp))
                            {
                                <option value="@comp">@comp</option>
                            }
                        }
                    </select>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary"
                            @onclick="@(() => showAddComponent = false)">
                        Cancel
                    </button>
                    <button type="button" class="btn btn-primary" @onclick="AddComponent">Add</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private const string BackendPR = "PR";
    private const string BackendSRK = "SRK";

    private string selectedBackend = "PR";
    private bool showLiquidLines = true;
    private bool showRetrogradeShading = true;
    private bool useDarkMode = false;
    private bool showDropout1 = true;
    private bool showDropout3 = true;
    private bool showDropout5 = true;
    private bool showDropout10 = true;
    private bool showDropout15 = true;
    private Dictionary<string, double> composition = new();
    private readonly string[] availableComponents =
        ["C1", "C2", "C3", "iC4", "nC4", "iC5", "nC5", "C6", "C7", "C8", "C9", "C10", "CO2", "N2", "H2S"];
    private bool isCalculating = false;
    private string errorMessage = string.Empty;
    private CoolPropPhaseEnvelopeService.PhaseEnvelopeResult? envelopeResult;
    private bool showAddComponent = false;
    private string selectedNewComponent = string.Empty;
    private PhaseEnvelopePlot? _plotComponent;

    protected override void OnInitialized() => LoadGasCondensate();

    private void LoadGasCondensate() => composition = new()
    {
        ["C1"] = 0.70,
        ["C2"] = 0.10,
        ["C3"] = 0.07,
        ["iC4"] = 0.02,
        ["nC4"] = 0.03,
        ["iC5"] = 0.02,
        ["nC5"] = 0.02,
        ["C6"] = 0.02,
        ["C7"] = 0.02
    };

    private void LoadDryGas() => composition = new()
    {
        ["C1"] = 0.85,
        ["C2"] = 0.08,
        ["C3"] = 0.04,
        ["nC4"] = 0.02,
        ["CO2"] = 0.01
    };

    private void LoadBlackOil() => composition = new()
    {
        ["C1"] = 0.40,
        ["C2"] = 0.08,
        ["C3"] = 0.07,
        ["nC4"] = 0.06,
        ["nC5"] = 0.05,
        ["C6"] = 0.08,
        ["C7"] = 0.10,
        ["C8"] = 0.08,
        ["C9"] = 0.05,
        ["C10"] = 0.03
    };

    private void ShowAddComponentModal()
    {
        showAddComponent = true;
        selectedNewComponent = string.Empty;
    }

    private void AddComponent()
    {
        if (!string.IsNullOrEmpty(selectedNewComponent) && !composition.ContainsKey(selectedNewComponent))
        {
            composition[selectedNewComponent] = 0.01;
            showAddComponent = false;
        }
    }

    private void RemoveComponent(string name) => composition.Remove(name);

    private void UpdateComposition(string name, string? value)
    {
        if (double.TryParse(value, out double v))
            composition[name] = Math.Clamp(v, 0, 1);
    }

    private async Task OnDisplayToggleChanged()
    {
        StateHasChanged();
        await Task.Yield();
        if (_plotComponent != null && envelopeResult != null)
            await _plotComponent.ForceRenderAsync();
    }

    private async Task OnLiquidToggleHeaderChanged(ChangeEventArgs e)
    {
        showLiquidLines = (bool)(e.Value ?? false);
        StateHasChanged();
        await Task.Yield();
        if (_plotComponent != null && envelopeResult != null)
            await _plotComponent.ForceRenderAsync();
    }

    private async Task OnRetrogradeToggleHeaderChanged(ChangeEventArgs e)
    {
        showRetrogradeShading = (bool)(e.Value ?? false);
        StateHasChanged();
        await Task.Yield();
        if (_plotComponent != null && envelopeResult != null)
            await _plotComponent.ForceRenderAsync();
    }

    private async Task OnThemeToggleChanged(ChangeEventArgs e)
    {
        useDarkMode = (bool)(e.Value ?? false);
        StateHasChanged();
        await Task.Yield();
        if (_plotComponent != null && envelopeResult != null)
            await _plotComponent.ForceRenderAsync();
    }

    private static string GetFluidBadgeClass(CoolPropPhaseEnvelopeService.FluidClassification fluidType) => fluidType switch
    {
        CoolPropPhaseEnvelopeService.FluidClassification.DryGas => "bg-info text-dark",
        CoolPropPhaseEnvelopeService.FluidClassification.WetGas => "bg-primary",
        CoolPropPhaseEnvelopeService.FluidClassification.GasCondensate => "bg-warning text-dark",
        CoolPropPhaseEnvelopeService.FluidClassification.VolatileOil => "bg-danger",
        CoolPropPhaseEnvelopeService.FluidClassification.BlackOil => "bg-dark",
        _ => "bg-secondary"
    };

    private async Task GenerateEnvelope()
    {
        isCalculating = true;
        errorMessage = string.Empty;
        StateHasChanged();

        try
        {
            var allFractions = new List<double>();
            if (showDropout1) allFractions.Add(0.01);
            if (showDropout3) allFractions.Add(0.03);
            if (showDropout5) allFractions.Add(0.05);
            if (showDropout10) allFractions.Add(0.10);
            if (showDropout15) allFractions.Add(0.15);

            var fractions = allFractions.Count > 0
                ? allFractions.ToArray()
                : [0.01, 0.03, 0.05, 0.10, 0.15];

            envelopeResult = await Task.Run(() =>
                EnvelopeService.GenerateEnvelopeOilfield(
                    selectedBackend, composition,
                    minTempF: -460, maxTempF: 1200,
                    points: 1000, liquidFractions: fractions));
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
            if (ex.InnerException != null)
                errorMessage += $"\nDetails: {ex.InnerException.Message}";
        }
        finally
        {
            isCalculating = false;
            StateHasChanged();
        }
    }
}