@using PhaseDiagram.Services.Thermo
@inject IJSRuntime JSRuntime

<div id="@_chartId" style="width:@(PlotWidth)px; height:@(PlotHeight)px;"></div>

@code {
    [Parameter] public string Title { get; set; } = "Phase Envelope Diagram";
    [Parameter] public CoolPropPhaseEnvelopeService.PhaseEnvelopeResult? EnvelopeData { get; set; }
    [Parameter] public List<ReferencePoint>? ReferencePoints { get; set; }
    [Parameter] public bool ShowLiquidLines { get; set; } = false;
    [Parameter] public bool ShowRetrogradeShading { get; set; } = true;
    [Parameter] public int PlotWidth { get; set; } = 1125;
    [Parameter] public int PlotHeight { get; set; } = 620;

    private readonly string _chartId = $"pe-{Guid.NewGuid():N}";
    private CoolPropPhaseEnvelopeService.PhaseEnvelopeResult? _lastRendered;
    private bool _lastShowLiquid;
    private bool _lastShowRetrograde;

    public class ReferencePoint
    {
        public string Label { get; set; } = string.Empty;
        public double Temperature { get; set; }
        public double Pressure { get; set; }
        public string Color { get; set; } = "#FF0000";
        public string Symbol { get; set; } = "circle";
    }

    private sealed record TPoint(double t, double p);
    private sealed record TRefPoint(string label, double t, double p, string color, string symbol);
    private sealed record TPlotData(
        TPoint[] bubble,
        TPoint[] dew,
        TPoint? critical,
        Dictionary<string, TPoint[]> liquidLines,
        TRefPoint[] referencePoints,
        bool showRetrograde);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        bool dataChanged = EnvelopeData != null && !ReferenceEquals(EnvelopeData, _lastRendered);
        bool toggleChanged = ShowLiquidLines != _lastShowLiquid
                          || ShowRetrogradeShading != _lastShowRetrograde;

        if (EnvelopeData != null && (dataChanged || toggleChanged))
        {
            _lastRendered = EnvelopeData;
            _lastShowLiquid = ShowLiquidLines;
            _lastShowRetrograde = ShowRetrogradeShading;
            await RenderChart();
        }
    }

    public async Task ForceRenderAsync()
    {
        _lastShowLiquid = ShowLiquidLines;
        _lastShowRetrograde = ShowRetrogradeShading;
        await RenderChart();
    }

    private async Task RenderChart()
    {
        if (EnvelopeData == null) return;

        var liquidLines = new Dictionary<string, TPoint[]>();
        if (ShowLiquidLines && EnvelopeData.LiquidLines.Count > 0)
        {
            foreach (var kvp in EnvelopeData.LiquidLines)
            {
                string key = kvp.Key.ToString("G17");
                liquidLines[key] = kvp.Value
                    .Select(p => new TPoint(p.T_F, p.P_psia))
                    .ToArray();
            }
        }

        var plotData = new TPlotData(
            bubble: EnvelopeData.Bubble.Select(p => new TPoint(p.T_F, p.P_psia)).ToArray(),
            dew: EnvelopeData.Dew.Select(p => new TPoint(p.T_F, p.P_psia)).ToArray(),
            critical: EnvelopeData.Critical.HasValue
                ? new TPoint(EnvelopeData.Critical.Value.Tcrit_F,
                             EnvelopeData.Critical.Value.Pcrit_psia)
                : null,
            liquidLines: liquidLines,
            referencePoints: ReferencePoints?
                .Select(rp => new TRefPoint(rp.Label, rp.Temperature, rp.Pressure, rp.Color, rp.Symbol))
                .ToArray() ?? [],
            showRetrograde: ShowRetrogradeShading
        );

        await JSRuntime.InvokeVoidAsync("phaseEnvelopePlot.render",
            _chartId, plotData, PlotWidth, PlotHeight);
    }
}